# Copia este archivo como ".env" para desarrollo local.
# En Vercel, esta variable se configura en el dashboard del proyecto
# (Settings > Environment Variables), no en este archivo.

# Desarrollo local: tu backend Django corriendo en tu máquina
VITE_URL_API=http://127.0.0.1:8000/api

