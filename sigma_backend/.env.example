# Copia este archivo como ".env" y ajusta los valores reales.
# NUNCA subas el archivo ".env" real a un repositorio (agregalo a .gitignore).

DJANGO_SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Pega aqui la "Connection string" que Supabase te da en:
# Project Settings > Database > Connection string > URI
# Tiene esta forma (reemplaza [YOUR-PASSWORD] por tu password real):
# postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
#
# Recomendado para Django: usa el modo "Connection pooling" (Transaction)
# de Supabase si vas a desplegar en un entorno serverless; para desarrollo
# local la conexion directa funciona bien.
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.TU_PROYECTO.supabase.co:5432/postgres

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
